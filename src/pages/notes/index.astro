---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Notes"
  description="Lecture notes, seminar notes, and reading notes by Wei Yang."
>
  <article class="page" aria-labelledby="notes-title">
    <p class="eyebrow">Notes</p>
    <h1 id="notes-title">Notes</h1>

    <p>
      This page is reserved for future lecture notes, seminar notes, and reading
      notes. Notes may be written in Markdown or MDX, with LaTeX-style
      mathematical notation rendered on the page.
    </p>

    <section aria-labelledby="examples-title">
      <h2 id="examples-title">Example</h2>
      <ul class="section-list">
        <li>
          <h3><a href="/notes/sample/">A Short MDX Math Example</a></h3>
          <p class="muted">
            A placeholder note showing inline and displayed mathematical
            notation.
          </p>
        </li>
      </ul>
    </section>
  </article>
</BaseLayout>

---
import BaseLayout from "./BaseLayout.astro";

type Frontmatter = {
  title?: string;
  description?: string;
  author?: string;
  date?: string | Date;
  updated?: string | Date;
};

type Props = {
  frontmatter: Frontmatter;
};

const { frontmatter } = Astro.props;
const title = frontmatter.title ?? "Untitled Note";
const description = frontmatter.description ?? "A mathematical note by Wei Yang.";

function normalizeDate(value?: string | Date) {
  if (!value) return "";

  if (Object.prototype.toString.call(value) === "[object Date]") {
    const dateValue = value as Date;
    return Number.isNaN(dateValue.getTime())
      ? ""
      : dateValue.toISOString().slice(0, 10);
  }

  const rawValue = String(value).trim();
  const dateOnlyMatch = rawValue.match(/^(\d{4}-\d{2}-\d{2})/);
  if (dateOnlyMatch) return dateOnlyMatch[1];

  const parsedDate = new Date(rawValue);
  return Number.isNaN(parsedDate.getTime())
    ? ""
    : parsedDate.toISOString().slice(0, 10);
}

function formatDate(value?: string | Date) {
  const normalizedDate = normalizeDate(value);
  if (!normalizedDate) return "";

  const [year, month, day] = normalizedDate.split("-").map(Number);

  return new Intl.DateTimeFormat("en", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  }).format(new Date(Date.UTC(year, month - 1, day)));
}

const postedDate = normalizeDate(frontmatter.date);
const updatedDate = normalizeDate(frontmatter.updated);
---

<BaseLayout title={title} description={description}>
  <article class="page note" aria-labelledby="note-title">
    <p class="eyebrow">Note</p>
    <h1 id="note-title">{title}</h1>

    {
      postedDate && (
        <p class="note-meta">
          {frontmatter.author && <>Author: {frontmatter.author} · </>}
          Added: <time datetime={postedDate}>{formatDate(postedDate)}</time>
          {
            updatedDate && (
              <>
                {" "}
                · Updated:{" "}
                <time datetime={updatedDate}>
                  {formatDate(updatedDate)}
                </time>
              </>
            )
          }
        </p>
      )
    }

    <slot />
  </article>
</BaseLayout>

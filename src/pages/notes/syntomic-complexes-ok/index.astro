---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const noteModules = Object.entries(
  import.meta.glob("./*.mdx", { eager: true }),
);

const notes = noteModules
  .map(([filePath, note]) => {
    const frontmatter = (note as { frontmatter?: unknown }).frontmatter as {
      title?: string;
      description?: string;
      author?: string;
      date?: string | Date;
    } | undefined;
    const slug = filePath.replace("./", "").replace(/\.mdx$/, "");

    return {
      title: frontmatter?.title ?? "Untitled Note",
      description: frontmatter?.description ?? "",
      author: frontmatter?.author ?? "",
      date: normalizeDate(frontmatter?.date),
      url: `/notes/syntomic-complexes-ok/${slug}/`,
    };
  })
  .sort((a, b) => b.date.localeCompare(a.date));

function normalizeDate(value?: string | Date) {
  if (!value) return "";

  if (Object.prototype.toString.call(value) === "[object Date]") {
    const dateValue = value as Date;
    return Number.isNaN(dateValue.getTime())
      ? ""
      : dateValue.toISOString().slice(0, 10);
  }

  const rawValue = String(value).trim();
  const dateOnlyMatch = rawValue.match(/^(\d{4}-\d{2}-\d{2})/);
  if (dateOnlyMatch) return dateOnlyMatch[1];

  const parsedDate = new Date(rawValue);
  return Number.isNaN(parsedDate.getTime())
    ? ""
    : parsedDate.toISOString().slice(0, 10);
}

function formatDate(value?: string | Date) {
  const normalizedDate = normalizeDate(value);
  if (!normalizedDate) return "Undated";

  const [year, month, day] = normalizedDate.split("-").map(Number);

  return new Intl.DateTimeFormat("en", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  }).format(new Date(Date.UTC(year, month - 1, day)));
}
---

<BaseLayout
  title="Syntomic Complexes over O_K"
  description="A series of notes on computing the cohomology of syntomic complexes over the ring of integers O_K."
>
  <article class="page" aria-labelledby="series-title">
    <p class="eyebrow"><a href="/notes/">Notes</a></p>
    <h1 id="series-title">Syntomic Complexes over O_K</h1>

    <p class="lead">
      This series collects notes on computations of the cohomology of syntomic
      complexes over the ring of integers O_K. The notes treat the same basic
      problem from different points of view.
    </p>

    <section aria-labelledby="series-notes-title">
      <h2 id="series-notes-title" class="list-section-title">
        Notes in This Series
      </h2>
      {
        notes.length > 0 ? (
          <ul class="section-list notes-list">
            {notes.map((note) => (
              <li>
                <h3 class="note-list-title">
                  <a href={note.url}>{note.title}</a>
                </h3>
                <p class="note-date">
                  {note.author && <>{note.author} · </>}
                  {note.date ? (
                    <time datetime={note.date}>{formatDate(note.date)}</time>
                  ) : (
                    "Undated"
                  )}
                </p>
                {note.description && <p class="muted">{note.description}</p>}
              </li>
            ))}
          </ul>
        ) : (
          <p class="muted">
            Notes will be added here as they are prepared.
          </p>
        )
      }
    </section>
  </article>
</BaseLayout>
